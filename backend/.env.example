# Generate a new key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-secret-key
DEBUG=True

# Comma-separated values
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

DB_NAME=newlife_matrimony
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

GOOGLE_CLIENT_ID=your-google-client-id-here

# Set to True when running behind HTTPS in production
SECURE_SSL_REDIRECT=False
